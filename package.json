{
  "name": "retirement-simulator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "prebuild": "node scripts/generate-build-info.js",
    "dev": "node scripts/generate-build-info.js && next dev --turbopack",
    "dev:clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && node scripts/generate-build-info.js && next dev --turbopack",
    "dev:port": "node scripts/generate-build-info.js && next dev --turbopack --port 3000",
    "build": "next build --turbopack",
    "start": "next start",
    "stop": "lsof -ti:3000 | xargs kill -9 2>/dev/null || echo 'Port 3000 is already free'",
    "restart": "pnpm run stop && pnpm run dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:deploy": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e",
    "improve:once": "bash scripts/improvement-loop.sh --once",
    "improve:loop": "bash scripts/improvement-loop.sh",
    "improve:deploy-loop": "IMPROVEMENT_LOOP_DEPLOY_INTERVAL_SECONDS=7200 bash scripts/improvement-loop.sh --deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@openai/codex": "^0.98.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@sparticuz/chromium": "^143.0.4",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "intl-messageformat": "^11.1.2",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "puppeteer-core": "^24.37.2",
    "react": "19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@react-pdf/types": "^2.9.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.15.1"
}
